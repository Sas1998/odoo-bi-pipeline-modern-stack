.env
.env.*
*.env
!.env.example

secrets/
*.key
*.pem
*.crt
*.token

# Airflow connection scripts containing credentials
airflow/scripts/setup_airflow_connections.py
airflow/scripts/*connections*
airflow/scripts/*secrets*

